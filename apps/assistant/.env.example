# ─── UNRLVL ASSISTANT — Variables de entorno ───────────────────────────────────
# Copiar a .env.local para desarrollo · Configurar en Vercel para producción

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Access Tokens
# Formato: CÓDIGO:NombreCliente:YYYY-MM-DD (separados por coma)
# El CÓDIGO es lo que el cliente escribe al entrar.
# Ejemplos:
ACCESS_TOKENS=ALPHA7K:Patricia Osorio:2026-04-04,BETA9X:Laura Rodriguez:2026-04-21

# ─── INSTRUCCIONES ──────────────────────────────────────────────────────────────
# Para añadir un nuevo acceso: añadir entrada al final con coma
# Para revocar: eliminar la entrada correspondiente
# Para extender: cambiar la fecha de expiración
# Los tokens son case-insensitive (ALPHA7K = alpha7k = Alpha7K)
# Sin Supabase ni base de datos — toda la gestión es por esta variable de entorno
